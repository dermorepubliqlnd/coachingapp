rules_version = '2';
// ==========================================================================
// BOOST Hub — Firestore Security Rules
// Version: 2026-07-14c  (adds create-time canCoach() check on sessions/actionPlans:
//                        creator must be the coachee's coach or an ancestor in the org tree)
// Publishing this version enables "My Team" for all coaches & managers.
// ==========================================================================
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function myDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    function iExist() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    function isAdmin() {
      return iExist() && myDoc().permissions.admin == true;
    }
    // Enterprise Dashboard access — a separate, explicitly-granted flag (independent of
    // the reporting hierarchy) for named Chiefs/execs who need org-wide read visibility
    // without full System Admin rights. Admin is a superset of Enterprise.
    function isEnterprise() {
      return isAdmin() || (iExist() && myDoc().permissions.enterprise == true);
    }
    function isFirstRun() {
      return isSignedIn() && request.auth.token.email == 'sbarlao@dermorepubliq.com';
    }
    // Create-time relationship check: requester must be the coachee's direct coach
    // OR anywhere above them in the org tree (reportsUpTo = any-depth skip-level) OR admin.
    // Reads the coachee's OWN user doc server-side, so a forged request can't fake it.
    function canCoach(coacheeId) {
      return isAdmin()
        || request.auth.uid == get(/databases/$(database)/documents/users/$(coacheeId)).data.coachId
        || (get(/databases/$(database)/documents/users/$(coacheeId)).data.reportsUpTo is list
            && request.auth.uid in get(/databases/$(database)/documents/users/$(coacheeId)).data.reportsUpTo);
    }

    // USERS — least-privilege directory:
    //  • own doc     (request.auth.uid == userId)
    //  • admin/enterprise (all)
    //  • coach/manager reading anyone in their own org subtree, any depth
    //                (request.auth.uid in resource.data.reportsUpTo)
    //  • coachee     reading their own assigned coach      (my coachId == userId)
    match /users/{userId} {
      // Single-document reads (get): full guarded conditions, safe on docs that
      // may be missing the reportsUpTo field.
      allow get: if isSignedIn() && (
        request.auth.uid == userId
        || isEnterprise()
        || resource.data.coachId == request.auth.uid
        || (resource.data.reportsUpTo is list && request.auth.uid in resource.data.reportsUpTo)
        || (iExist() && myDoc().coachId == userId)
      );
      // Collection queries (list): conditions must line up with the query's own
      // constraints. NO "is list" guard here — that guard blocks Firestore's
      // query-time validation of array-contains and silently denies the whole query.
      // The app's coach/manager "My Team" query is where('reportsUpTo','array-contains',uid).
      allow list: if isSignedIn() && (
        isEnterprise()
        || resource.data.coachId == request.auth.uid
        || request.auth.uid in resource.data.reportsUpTo
      );
      allow create: if isAdmin() || isFirstRun();
      allow update: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin();
    }

    // SESSIONS — coach (owner), coachee (subject), admin/enterprise (all), or a
    // Manager/Senior Manager reading anywhere in their own org subtree (read-only —
    // editing stays limited to the coach who ran it / the coachee acknowledging it).
    // App queries are constrained by coachId==uid, coacheeId==uid, or
    // coacheeReportsUpTo array-contains uid, so these reads are permitted.
    match /sessions/{sessionId} {
      allow get: if isSignedIn() && (
        isEnterprise() ||
        resource.data.coachId == request.auth.uid ||
        resource.data.coacheeId == request.auth.uid ||
        (resource.data.coacheeReportsUpTo is list && request.auth.uid in resource.data.coacheeReportsUpTo)
      );
      // list: clean patterns so coachId==, coacheeId== and coacheeReportsUpTo
      // array-contains queries all validate (no is-list guard).
      allow list: if isSignedIn() && (
        isEnterprise() ||
        resource.data.coachId == request.auth.uid ||
        resource.data.coacheeId == request.auth.uid ||
        request.auth.uid in resource.data.coacheeReportsUpTo
      );
      allow create: if isSignedIn()
        && request.resource.data.coachId == request.auth.uid
        && canCoach(request.resource.data.coacheeId);
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.coachId == request.auth.uid ||
        resource.data.coacheeId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // ACTION PLANS — same ownership + hierarchy-rollup model as sessions.
    match /actionPlans/{apId} {
      allow get: if isSignedIn() && (
        isEnterprise() ||
        resource.data.coachId == request.auth.uid ||
        resource.data.coacheeId == request.auth.uid ||
        (resource.data.coacheeReportsUpTo is list && request.auth.uid in resource.data.coacheeReportsUpTo)
      );
      allow list: if isSignedIn() && (
        isEnterprise() ||
        resource.data.coachId == request.auth.uid ||
        resource.data.coacheeId == request.auth.uid ||
        request.auth.uid in resource.data.coacheeReportsUpTo
      );
      allow create: if isSignedIn()
        && request.resource.data.coachId == request.auth.uid
        && canCoach(request.resource.data.coacheeId);
      allow update: if isSignedIn() && (
        isAdmin() ||
        resource.data.coachId == request.auth.uid ||
        resource.data.coacheeId == request.auth.uid
      );
      allow delete: if isAdmin();

      match /comments/{commentId} {
        allow read:   if isSignedIn();
        allow create: if isSignedIn();
        allow update: if isSignedIn() && resource.data.authorId == request.auth.uid;
        allow delete: if isAdmin();
      }
    }

    match /departments/{deptId} {
      allow read:  if isSignedIn();
      allow write: if isAdmin();
    }

    match /settings/{settingId} {
      allow read:  if isSignedIn() || isFirstRun();
      allow write: if isAdmin() || isFirstRun();
    }

    match /meta/{metaId} {
      allow read, write: if isSignedIn();
    }

    match /auditLog/{logId} {
      allow read:   if isAdmin();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    match /deletionRequests/{reqId} {
      allow read:   if isAdmin() || (isSignedIn() && resource.data.requestedBy == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if false;
    }
  }
}
